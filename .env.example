# =============================================================================
# SmartFoundation - Environment Variables Template
# =============================================================================
# Copy this file to .env and add your real values.
# Never commit .env to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# AI Provider API Keys (optional, based on your local tooling)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
AZURE_OPENAI_API_KEY=
OLLAMA_API_KEY=

# MCP/tooling keys
CONTEXT7_API_KEY=

# -----------------------------------------------------------------------------
# Additional service keys/endpoints
# Add project-specific secrets below as needed.
# -----------------------------------------------------------------------------
# EXAMPLE_SERVICE_API_KEY=
# EXAMPLE_SERVICE_ENDPOINT=

# -----------------------------------------------------------------------------
# Best Practices
# -----------------------------------------------------------------------------
# 1) Keep secrets only in .env (local machine)
# 2) Use separate keys for local/dev/prod
# 3) Rotate keys regularly
# 4) Set usage/billing limits where available
