@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model SmartFoundation.UI.ViewModels.SmartPage.SmartPageViewModel

@{
    Layout = null;
    ViewData["Title"] = Model.PageTitle ?? "الكثافة السكانية في الأحياء السكنية";
}
<!doctype html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/statistics.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Fontawesome6-5-0.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/smartcharts/smartcharts.populationdensity.css" asp-append-version="true" />

    <style>
        html,
        body {
            width: 100%;
            height: 100%;
            margin: 0;
            overflow: auto;
            background: #edf2f7;
        }

        .pd-page {
            width: 100%;
            height: 100dvh;
            padding: 0;
            margin: 0;
            overflow: auto;
        }

        #populationDensityDashboard > .grid {
            max-width: 1400px;
            margin: 0 auto;
            gap: 0 !important;
            padding: 10px 16px 10px !important;
            height: 100%;
        }

        #populationDensityDashboard > .grid > div {
            min-height: 0;
            height: 100%;
        }

        #populationDensityDashboard .pdm-dashboard-card {
            min-height: 0;
            height: 100%;
        }
    </style>
</head>
<body>
    <main class="pd-page">
        @if (Model?.Charts is not null)
        {
            @await Component.InvokeAsync("SmartCharts", new { model = Model.Charts, embedded = true })
        }
    </main>

    <script src="~/lib/chartjs/chart.umd.js" asp-append-version="true"></script>
    <script src="~/lib/chartjs/chartjs-plugin-datalabels.min.js" asp-append-version="true"></script>
    <script src="~/js/smartcharts/smartcharts.populationdensity.js" asp-append-version="true"></script>
</body>
</html>
