<!-- Page Header (Breadcrumb / Page tools) -->
<div id="page-header" class="fixed z-40">
    <div class="px-3 py-2 lg:px-5" dir="rtl">
        <div id="page-header-content" class="flex items-center justify-between gap-3">

            @{
                var controller = (ViewContext.RouteData.Values["controller"]?.ToString()) ?? "";
                var action = (ViewContext.RouteData.Values["action"]?.ToString()) ?? "";

                var crumbs = new List<MenuBreadcrumb.Crumb>();

                var json = Context.Session.GetString("MENU_TREE");
                if (!string.IsNullOrWhiteSpace(json))
                {
                    var tree = JsonSerializer.Deserialize<List<MenuItem>>(json) ?? new List<MenuItem>();
                    crumbs = MenuBreadcrumb.Get(tree, controller, action);
                }
            }

            <nav class="sf-bc" aria-label="Breadcrumb">
                <i class="fa-solid fa-location-dot sf-bc-icon" aria-hidden="true"></i>

                <ol class="sf-bc-text">
                    <li><a href="/Home">الرئيسية</a></li>

                    @if (crumbs.Count > 0)
                    {
                        for (int i = 0; i < crumbs.Count; i++)
                        {
                            var c = crumbs[i];
                            var isLast = i == crumbs.Count - 1;

                            <li class="sep" aria-hidden="true">◂</li>

                            if (!isLast && !string.IsNullOrWhiteSpace(c.Url))
                            {
                                <li><a href="@c.Url">@c.Text</a></li>
                            }
                            else
                            {
                                <li class="current" aria-current="page">@c.Text</li>
                            }
                        }
                    }
                </ol>
            </nav>
            <div class="flex items-center gap-2"></div>
        </div>
    </div>
</div>


<script>
    (function () {
        const savedSidebarState = localStorage.getItem('sidebarState');
        const body = document.body;

        if (!body) return;

        if (window.innerWidth >= 1024) {
            if (savedSidebarState === 'sidebar-collapsed') {
                body.classList.add('sidebar-collapsed');
                body.classList.remove('sidebar-pinned', 'with-sidebar-open');
            } else {
                body.classList.add('sidebar-pinned');
                body.classList.remove('sidebar-collapsed', 'with-sidebar-open');
            }
        }
    })();
</script>

