    <script>
        (function() {
            console.log('🔒 FORCE PASSWORD CHANGE - Simple Mode');
            
            // ✅ Simple disable function
            const disableNavigation = () => {
                // Disable sidebar menu links
                document.querySelectorAll('aside#logo-sidebar .sidebar-link').forEach(link => {
                    link.classList.add('force-disabled');
                });
                
                // Disable header Home link
                document.querySelectorAll('nav#top-header a[href="/Home"]').forEach(link => {
                    link.classList.add('force-disabled');
                });
                
                // Disable dropdown items (except logout)
                document.querySelectorAll('#user-dropdown a:not([href="/Login/Logout"])').forEach(link => {
                    link.classList.add('force-disabled');
                });
                
                // Disable sidebar controls
                document.querySelectorAll('aside#logo-sidebar button[data-menu-toggle]').forEach(btn => {
                    btn.classList.add('force-disabled');
                });
                
                const pinBtn = document.getElementById('pin-sidebar');
                const toggleBtn = document.getElementById('toggle-sidebar');
                if (pinBtn) pinBtn.classList.add('force-disabled');
                if (toggleBtn) toggleBtn.classList.add('force-disabled');
            };
            
            // Execute
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', disableNavigation);
            } else {
                disableNavigation();
            }
            
            // DOMContentLoaded
            document.addEventListener('DOMContentLoaded', () => {
                disableNavigation();
                document.body.classList.add('modal-open');
                
                setTimeout(() => {
                    document.getElementById('force-current-password')?.focus();
                }, 500);
                
                // Prevent ESC
                document.addEventListener('keydown', (e) => {
                    if (e.key === 'Escape') {
                        e.preventDefault();
                        return false;
                    }
                }, true);
            });
            
            // Password strength
            document.getElementById('force-new-password')?.addEventListener('input', function(e) {
                const password = e.target.value;
                const strengthDiv = document.getElementById('force-password-strength');
                const strengthBar = document.getElementById('force-strength-bar');
                const strengthText = document.getElementById('force-strength-text');
                
                if (password.length === 0) {
                    strengthDiv?.classList.add('hidden');
                    return;
                }
                
                strengthDiv?.classList.remove('hidden');
                
                const checks = {
                    length: password.length >= 8,
                    uppercase: /[A-Z]/.test(password),
                    lowercase: /[a-z]/.test(password),
                    number: /[0-9]/.test(password)
                };
                
                updateForceCheck('force-check-length', checks.length);
                updateForceCheck('force-check-uppercase', checks.uppercase);
                updateForceCheck('force-check-lowercase', checks.lowercase);
                updateForceCheck('force-check-number', checks.number);
                
                let strength = 0;
                if (checks.length) strength += 25;
                if (checks.uppercase) strength += 25;
                if (checks.lowercase) strength += 25;
                if (checks.number) strength += 25;
                
                let color = '', text = '';
                if (strength < 50) { color = 'bg-red-500'; text = 'ضعيفة'; }
                else if (strength < 100) { color = 'bg-yellow-500'; text = 'متوسطة'; }
                else { color = 'bg-green-500'; text = 'قوية'; }
                
                if (strengthBar) {
                    strengthBar.style.width = strength + '%';
                    strengthBar.className = `h-full transition-all duration-300 ${color}`;
                }
                if (strengthText) {
                    strengthText.textContent = text;
                    strengthText.className = `text-xs font-medium ${color.replace('bg-', 'text-')}`;
                }
            });
            
            function updateForceCheck(id, isValid) {
                const element = document.getElementById(id);
                if (!element) return;
                const icon = element.querySelector('i');
                if (icon) {
                    icon.className = isValid
                        ? 'fa-solid fa-circle-check text-green-400'
                        : 'fa-solid fa-circle-xmark text-red-400';
                }
            }
            
            // Form submission
            document.getElementById('force-change-password-form')?.addEventListener('submit', async function(e) {
                e.preventDefault();
                
                const errorDiv = document.getElementById('force-password-error');
                const submitBtn = this.querySelector('button[type="submit"]');
                
                const currentPassword = this.currentPassword.value.trim();
                const newPassword = this.newPassword.value.trim();
                const confirmPassword = this.confirmPassword.value.trim();
                
                errorDiv?.classList.add('hidden');
                
                const showError = (msg) => {
                    if (errorDiv) {
                        errorDiv.textContent = msg;
                        errorDiv.classList.remove('hidden');
                        errorDiv.classList.add('animate-shake');
                        setTimeout(() => errorDiv.classList.remove('animate-shake'), 500);
                    }
                };
                
                if (!currentPassword || !newPassword || !confirmPassword) {
                    showError('❌ جميع الحقول مطلوبة');
                    return;
                }
                if (newPassword !== confirmPassword) {
                    showError('❌ كلمة المرور الجديدة وتأكيد كلمة المرور غير متطابقتين');
                    return;
                }
                if (newPassword.length < 8) {
                    showError('❌ كلمة المرور يجب أن لا تقل عن 8 خانات');
                    return;
                }
                if (!/[A-Z]/.test(newPassword)) {
                    showError('❌ يجب أن تحتوي على حرف كبير (A-Z)');
                    return;
                }
                if (!/[a-z]/.test(newPassword)) {
                    showError('❌ يجب أن تحتوي على حرف صغير (a-z)');
                    return;
                }
                if (!/[0-9]/.test(newPassword)) {
                    showError('❌ يجب أن تحتوي على رقم (0-9)');
                    return;
                }
                if (currentPassword === newPassword) {
                    showError('❌ كلمة المرور الجديدة يجب أن تختلف عن الحالية');
                    return;
                }
                
                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i>جاري تغيير كلمة المرور...';
                }
                
                try {
                    const response = await fetch('/Login/ChangePassword', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({
                            oldPassword: currentPassword,
                            newPassword: newPassword
                        })
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        alert('✅ تم تغيير كلمة المرور بنجاح! سيتم تسجيل خروجك الآن...');
                        setTimeout(() => {
                            window.location.href = '/Login?logout=2';
                        }, 1000);
                    } else {
                        showError(result.message || '❌ فشل تغيير كلمة المرور');
                        if (submitBtn) {
                            submitBtn.disabled = false;
                            submitBtn.innerHTML = '<i class="fa-solid fa-shield-halved me-2"></i>تغيير كلمة المرور الآن';
                        }
                    }
                } catch (error) {
                    console.error('❌ Error:', error);
                    showError('❌ حدث خطأ أثناء تغيير كلمة المرور');
                    if (submitBtn) {
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = '<i class="fa-solid fa-shield-halved me-2"></i>تغيير كلمة المرور الآن';
                    }
                }
            });
            
        })();
    </script>
}