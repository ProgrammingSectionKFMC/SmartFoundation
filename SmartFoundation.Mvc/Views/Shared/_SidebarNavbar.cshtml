<script>
    function togglePasswordVisibility(inputId) {
        const input = document.getElementById(inputId);
        const icon = input.nextElementSibling.querySelector('i');
        
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.remove('fa-eye');
            icon.classList.add('fa-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.remove('fa-eye-slash');
            icon.classList.add('fa-eye');
        }
    }

    document.getElementById('change-password-form')?.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const errorDiv = document.getElementById('password-error');
        const submitBtn = this.querySelector('button[type="submit"]');
        
        // ✅ FIXED: Add .trim() to remove any hidden spaces
        const currentPassword = this.currentPassword.value.trim();
        const newPassword = this.newPassword.value.trim();
        const confirmPassword = this.confirmPassword.value.trim();
        
        // ✅ Debug logging - will help identify the issue
        console.log('=== Password Validation Debug ===');
        console.log('Current Password:', JSON.stringify(currentPassword));
        console.log('New Password:', JSON.stringify(newPassword));
        console.log('Confirm Password:', JSON.stringify(confirmPassword));
        console.log('Lengths:', {
            current: currentPassword.length,
            new: newPassword.length,
            confirm: confirmPassword.length
        });
        console.log('Are they equal?', newPassword === confirmPassword);
        console.log('Character codes (new):', Array.from(newPassword).map((c, i) => `${i}: "${c}" (${c.charCodeAt(0)})`));
        console.log('Character codes (confirm):', Array.from(confirmPassword).map((c, i) => `${i}: "${c}" (${c.charCodeAt(0)})`));
        
        errorDiv.classList.add('hidden');
        
        // ✅ Check empty fields first
        if (!currentPassword || !newPassword || !confirmPassword) {
            errorDiv.textContent = 'جميع الحقول مطلوبة';
            errorDiv.classList.remove('hidden');
            return;
        }
        
        // ✅ Check password match
        if (newPassword !== confirmPassword) {
            console.error('❌ Passwords do not match!');
            console.error('New:', newPassword, '(length:', newPassword.length, ')');
            console.error('Confirm:', confirmPassword, '(length:', confirmPassword.length, ')');
            
            errorDiv.innerHTML = `
                كلمة المرور الجديدة وتأكيد كلمة المرور غير متطابقتين<br>
                <small class="text-xs opacity-75">
                    الطول: ${newPassword.length} ≠ ${confirmPassword.length}
                </small>
            `;
            errorDiv.classList.remove('hidden');
            return;
        }
        
        // ✅ Check minimum length (8 characters)
        if (newPassword.length < 8) {
            errorDiv.textContent = 'كلمة المرور يجب أن لا تقل عن 8 خانات';
            errorDiv.classList.remove('hidden');
            return;
        }
        
        // ✅ Check contains at least one UPPERCASE letter
        if (!/[A-Z]/.test(newPassword)) {
            errorDiv.textContent = 'كلمة المرور يجب أن تحتوي على حرف إنجليزي كبير واحد على الأقل (A-Z)';
            errorDiv.classList.remove('hidden');
            return;
        }
        
        // ✅ Check contains at least one lowercase letter
        if (!/[a-z]/.test(newPassword)) {
            errorDiv.textContent = 'كلمة المرور يجب أن تحتوي على حرف إنجليزي صغير واحد على الأقل (a-z)';
            errorDiv.classList.remove('hidden');
            return;
        }
        
        // ✅ Check contains at least one number
        if (!/[0-9]/.test(newPassword)) {
            errorDiv.textContent = 'كلمة المرور يجب أن تحتوي على رقم واحد على الأقل (0-9)';
            errorDiv.classList.remove('hidden');
            return;
        }
        
        // ✅ Check not same as current
        if (currentPassword === newPassword) {
            errorDiv.textContent = 'كلمة المرور الجديدة يجب أن تختلف عن الحالية';
            errorDiv.classList.remove('hidden');
            return;
        }
        
        console.log('✅ All validations passed!');
        
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i>جاري الحفظ...';
        
        try {
            console.log('📤 Sending request to server...');
            
            const response = await fetch('/Login/ChangePassword', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({
                    oldPassword: currentPassword,
                    newPassword: newPassword
                })
            });
            
            console.log('📥 Response status:', response.status);
            
            const result = await response.json();
            console.log('📥 Response data:', result);
            
            if (result.success) {
                console.log('✅ Password changed successfully!');
                
                if (typeof toastr !== 'undefined') {
                    toastr.success(result.message || 'تم تغيير كلمة المرور بنجاح');
                } else {
                    alert(result.message || 'تم تغيير كلمة المرور بنجاح');
                }
                
                const modalInstance = FlowbiteInstances?.getInstance('Modal', 'change-password-modal');
                if (modalInstance) modalInstance.hide();
                
                this.reset();
                
                setTimeout(() => {
                    window.location.href = '/Login?logout=2';
                }, 2000);
                
            } else {
                console.error('❌ Server returned error:', result.message);
                errorDiv.textContent = result.message || 'فشل تغيير كلمة المرور';
                errorDiv.classList.remove('hidden');
            }
            
        } catch (error) {
            console.error('❌ Request failed:', error);
            errorDiv.textContent = 'حدث خطأ أثناء تغيير كلمة المرور';
            errorDiv.classList.remove('hidden');
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = '<i class="fa-solid fa-check me-2"></i>حفظ كلمة المرور';
        }
    });
    
    // ✅ Auto-trim on blur to prevent user confusion
    document.querySelectorAll('#change-password-form input[type="password"]').forEach(input => {
        input.addEventListener('blur', function() {
            this.value = this.value.trim();
        });
    });
</script>

<script>
    document.getElementById('new-password')?.addEventListener('input', function(e) {
        const password = e.target.value;
        const strengthDiv = document.getElementById('password-strength');
        const strengthBar = document.getElementById('strength-bar');
        const strengthText = document.getElementById('strength-text');
        
        if (password.length === 0) {
            strengthDiv.classList.add('hidden');
            return;
        }
        
        strengthDiv.classList.remove('hidden');
        
        let strength = 0;
        const checks = {
            length: password.length >= 8,
            uppercase: /[A-Z]/.test(password),
            lowercase: /[a-z]/.test(password),
            number: /[0-9]/.test(password)
        };
        
        // Update checkmarks
        updateCheck('check-length', checks.length);
        updateCheck('check-uppercase', checks.uppercase);
        updateCheck('check-lowercase', checks.lowercase);
        updateCheck('check-number', checks.number);
        
        // Calculate strength
        if (checks.length) strength += 25;
        if (checks.uppercase) strength += 25;
        if (checks.lowercase) strength += 25;
        if (checks.number) strength += 25;
        
        let color = '';
        let text = '';
        
        if (strength < 50) {
            color = 'bg-red-500';
            text = 'ضعيفة';
        } else if (strength < 100) {
            color = 'bg-yellow-500';
            text = 'متوسطة';
        } else {
            color = 'bg-green-500';
            text = 'قوية';
        }
        
        strengthBar.style.width = strength + '%';
        strengthBar.className = `h-full transition-all duration-300 ${color}`;
        strengthText.textContent = text;
        strengthText.className = `text-xs font-medium ${color.replace('bg-', 'text-')}`;
    });
    
    function updateCheck(id, isValid) {
        const element = document.getElementById(id);
        if (!element) return;
        
        const icon = element.querySelector('i');
        if (isValid) {
            icon.className = 'fa-solid fa-circle-check text-green-400';
        } else {
            icon.className = 'fa-solid fa-circle-xmark text-red-400';
        }
    }
</script>

