@using SmartFoundation.UI.ViewModels.SmartPage
@model SmartFoundation.UI.ViewModels.SmartPage.SmartPageViewModel

@{
    var hasPanelContent =
    Model.Form is not null
    || Model.DatePicker is not null
    || Model.Print is not null
    || Model.TableDS is not null
    || Model.TableDS1 is not null
    || Model.TableDS2 is not null
    || Model.TableDS3 is not null
    || Model.TableDS4 is not null
    || Model.TableDS5 is not null
    || Model.Table is not null;

    var panel = Model.Panel ?? new SmartPagePanelConfig();
    var panelTitle = panel.Title ?? Model.PanelTitle ?? Model.PageTitle ?? "";
    var panelIcon = panel.Icon ?? Model.PanelIcon ?? "fa-layer-group";
    var panelSubtitle = panel.Subtitle ?? "";
    var panelDescription = panel.Description ?? "";
    var panelBadges = panel.Badges?.Where(x => x.Visible).ToList() ?? new List<SmartPagePanelBadge>();
    var pageAlerts = Model.Alerts?.Where(x => x.Visible && !string.IsNullOrWhiteSpace(x.Message)).ToList() ?? new List<SmartPageAlert>();
    var showPanelHeader = panel.Show && (!string.IsNullOrWhiteSpace(panelTitle)
        || (!string.IsNullOrWhiteSpace(panelSubtitle) && panel.ShowSubtitle)
        || (!string.IsNullOrWhiteSpace(panelDescription) && panel.ShowDescription)
        || (panel.ShowBadges && panelBadges.Count > 0));
}

@if (Model.Charts is not null)
{
    <div class="w-full">
        <div class="rounded-sm border border-gray-100 bg-white p-6 shadow-sm">
            @await Component.InvokeAsync("SmartCharts", new { model = Model.Charts, embedded = true })
        </div>
    </div>
}

@if (hasPanelContent)
{
    <div x-data="{ open:true }" class="sf-panel mt-6">
        @if (pageAlerts.Count > 0)
        {
            <div class="sf-page-alerts" aria-live="polite" aria-atomic="true">
                @foreach (var alert in pageAlerts)
                {
                    var alertTone = string.IsNullOrWhiteSpace(alert.Tone) ? "info" : alert.Tone.Trim().ToLowerInvariant();
                    var alertIcon = !string.IsNullOrWhiteSpace(alert.Icon)
                        ? alert.Icon
                        : alertTone switch
                        {
                            "success" => "fa-solid fa-circle-check",
                            "warning" => "fa-solid fa-triangle-exclamation",
                            "danger" => "fa-solid fa-circle-exclamation",
                            _ => "fa-solid fa-circle-info"
                        };
                    var alertAutoDismissMs = alert.AutoDismissMs > 0 ? alert.AutoDismissMs : 0;
                    var alertStateKey = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(
                        $"{Model.PageTitle}|{alertTone}|{alert.Title}|{alert.Message}"));

                    <div class="sf-page-alert is-@alertTone"
                         x-data="{
                             storageKey: 'sf-alert:@alertStateKey',
                             open: false,
                             init() {
                                 try {
                                     this.open = sessionStorage.getItem(this.storageKey) !== '1';
                                 } catch {
                                     this.open = true;
                                 }

                                 document.addEventListener('click', (event) => {
                                     const anchor = event.target.closest('a[href]');
                                     if (!anchor) return;

                                     const href = anchor.getAttribute('href');
                                     if (!href || href.startsWith('#') || href.startsWith('javascript:')) return;

                                     try {
                                         const current = new URL(window.location.href);
                                         const target = new URL(href, window.location.origin);

                                         const samePageFlow =
                                             target.origin === current.origin
                                             && target.pathname.toLowerCase() === current.pathname.toLowerCase();

                                         if (!samePageFlow) {
                                             sessionStorage.removeItem(this.storageKey);
                                         }
                                     } catch {}
                                 }, true);

                                 if (this.open && @alertAutoDismissMs > 0) {
                                     setTimeout(() => this.close(), @alertAutoDismissMs);
                                 }
                             },
                             close() {
                                 this.open = false;
                                 try { sessionStorage.setItem(this.storageKey, '1'); } catch {}
                             }
                         }"
                         x-cloak
                         x-show="open"
                         style="@(alertAutoDismissMs > 0 ? $"--sf-alert-duration:{alertAutoDismissMs}ms;" : "")"
                         role="status"
                         aria-live="polite"
                         x-transition:enter="sf-alert-enter"
                         x-transition:enter-start="sf-alert-enter-start"
                         x-transition:enter-end="sf-alert-enter-end"
                         x-transition:leave="sf-alert-leave"
                         x-transition:leave-start="sf-alert-leave-start"
                         x-transition:leave-end="sf-alert-leave-end">
                        <div class="sf-page-alert__rail" aria-hidden="true"></div>

                        <div class="sf-page-alert__icon">
                            <i class="@alertIcon"></i>
                        </div>

                        <div class="sf-page-alert__content">
                            @if (!string.IsNullOrWhiteSpace(alert.Title))
                            {
                                <div class="sf-page-alert__title">@alert.Title</div>
                            }

                            <div class="sf-page-alert__message">@alert.Message</div>
                        </div>

                        @if (alert.Dismissible)
                        {
                            <button type="button"
                                    class="sf-page-alert__close"
                                    x-on:click="close()"
                                    aria-label="اغلاق التنبيه">
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        }

                        @if (alertAutoDismissMs > 0)
                        {
                            <div class="sf-page-alert__timer" aria-hidden="true"></div>
                        }
                    </div>
                }
            </div>
        }

        @if (showPanelHeader)
        {
            <div class="sf-panel-header">
                <div class="sf-panel-head @(string.Equals(panel.Layout, "compact", StringComparison.OrdinalIgnoreCase) ? "is-compact" : "is-hero")">
                    <div class="sf-panel-head__identity">
                        @if (panel.ShowIcon)
                        {
                            <span class="sf-panel-head__icon">
                                <i class="fa-solid @panelIcon"></i>
                            </span>
                        }

                        <div class="sf-panel-head__content">
                            <div class="sf-panel-head__titleRow">
                                <h3 class="sf-panel-head__title">@panelTitle</h3>
                            </div>

                            @if (panel.ShowSubtitle && !string.IsNullOrWhiteSpace(panelSubtitle))
                            {
                                <div class="sf-panel-head__subtitle">@panelSubtitle</div>
                            }

                            @if (panel.ShowDescription && !string.IsNullOrWhiteSpace(panelDescription))
                            {
                                <div class="sf-panel-head__desc">@panelDescription</div>
                            }
                        </div>
                    </div>

                    @if (panel.ShowBadges && panelBadges.Count > 0)
                    {
                        <div class="sf-panel-head__badges">
                            @foreach (var badge in panelBadges)
                            {
                                <div class="sf-panel-badge is-@badge.Tone">
                                    @if (!string.IsNullOrWhiteSpace(badge.Icon))
                                    {
                                        <i class="@badge.Icon sf-panel-badge__icon"></i>
                                    }

                                    <span class="sf-panel-badge__label">@badge.Label</span>

                                    @if (!string.IsNullOrWhiteSpace(badge.Value))
                                    {
                                        <span class="sf-panel-badge__value">@badge.Value</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        <div class="sf-panel-body" x-show="open">
            @if (Model.Form is not null)
            {
                @await Component.InvokeAsync("SmartForm", new { model = Model.Form, embedded = true })
            }

            @if (Model.DatePicker is not null)
            {
                @await Component.InvokeAsync("SmartDatePicker", new { model = Model.DatePicker, embedded = true })
            }
            @if (Model.Print is not null)
            {
                @await Component.InvokeAsync("SmartPrint", new { model = Model.Print, embedded = true })
            }

            @if (Model.TableDS is not null)
            {
                @await Component.InvokeAsync("SmartTableDS", new { model = Model.TableDS, embedded = true })
            }
            @if (Model.TableDS1 is not null)
            {
                @await Component.InvokeAsync("SmartTableDS", new { model = Model.TableDS1, embedded = true })
            }
            @if (Model.TableDS2 is not null)
            {
                @await Component.InvokeAsync("SmartTableDS", new { model = Model.TableDS2, embedded = true })
            }
            @if (Model.TableDS3 is not null)
            {
                @await Component.InvokeAsync("SmartTableDS", new { model = Model.TableDS3, embedded = true })
            }
            @if (Model.TableDS4 is not null)
            {
                @await Component.InvokeAsync("SmartTableDS", new { model = Model.TableDS4, embedded = true })
            }
            @if (Model.TableDS5 is not null)
            {
                @await Component.InvokeAsync("SmartTableDS", new { model = Model.TableDS5, embedded = true })
            }

            @if (Model.Table is not null)
            {
                @await Component.InvokeAsync("SmartTable", new { model = Model.Table, embedded = true })
            }
        </div>
    </div>
}

@* ===== Global Print Iframe (ONE TIME) ===== *@
<iframe id="sf-print-frame"
        style="display:none;width:0;height:0;border:0"></iframe>


<script>

    window.__sfPrintSession = window.__sfPrintSession || { active: false, canceled: false };

    window.sfOpenPrint = function (url, opts) {
        opts = opts || {};
        const onReady = typeof opts.onReady === "function" ? opts.onReady : null;
        const onBeforePrint = typeof opts.onBeforePrint === "function" ? opts.onBeforePrint : null;
        const onAfterPrint = typeof opts.onAfterPrint === "function" ? opts.onAfterPrint : null;
        const onError = typeof opts.onError === "function" ? opts.onError : null;

        const frame = document.getElementById('sf-print-frame');
        if (!frame) {
            console.error('sf-print-frame not found');
            onError && onError(new Error("sf-print-frame not found"));
            return null;
        }


        window.__sfPrintSession.active = true;
        window.__sfPrintSession.canceled = false;

        // cache buster
        try {
            const u = new URL(url, window.location.origin);
            u.searchParams.set('_t', Date.now().toString());
            url = u.toString();
        } catch { }

        const cleanup = () => {
            try { frame.onload = null; } catch {}
            frame.src = "about:blank";
            window.__sfPrintSession.active = false;
            window.__sfPrintSession.canceled = false;
        };

        frame.onload = function () {
            try {

                if (window.__sfPrintSession.canceled) {
                    cleanup();
                    return;
                }

                if (onReady) onReady();

                const w = frame.contentWindow;
                if (!w) throw new Error("frame.contentWindow is null");

                if (onAfterPrint) { try { w.addEventListener("afterprint", onAfterPrint, { once: true }); } catch {} }
                if (onBeforePrint) { try { w.addEventListener("beforeprint", onBeforePrint, { once: true }); } catch {} }


                if (onBeforePrint) onBeforePrint();


                if (window.__sfPrintSession.canceled) {
                    cleanup();
                    return;
                }

                w.focus();
                w.print();

                // fallback
                setTimeout(() => { onAfterPrint && onAfterPrint(); }, 1500);

            } catch (e) {
                console.error('Print failed:', e);
                onError && onError(e);
            }
        };

        frame.src = url;

        return {
            cancel: function () {
                window.__sfPrintSession.canceled = true;
                cleanup();
            }
        };
    };
</script>
